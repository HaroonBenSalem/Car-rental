# Neon Database Configuration (UPDATE WITH YOUR CREDENTIALS)

# Copy this and update with your actual Neon connection details
# Then update the values in backend/src/main/resources/application.properties

# Example Neon connection string:
# postgresql://neondb_owner:password@ep-xxxx-xxxx.us-east-1.neon.tech/carrental

SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host:5432/carrental
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=your_password

# JWT Secret (generate a strong random string)
APP_JWT_SECRET=your-256-bit-secret-key-here-change-in-production
APP_JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080
